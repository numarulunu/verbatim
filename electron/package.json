{
  "name": "transcriptor",
  "version": "1.0.0",
  "description": "Transcriptor — batch transcription with Whisper, OCR, and speaker diarization",
  "main": "main.js",
  "author": "numarulunu",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.transcriptor.app",
    "productName": "Transcriptor",
    "artifactName": "Transcriptor-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Transcriptor"
    },
    "publish": {
      "provider": "github",
      "owner": "numarulunu",
      "repo": "transcriptor"
    },
    "files": [
      "main.js",
      "preload.js",
      "resources/**/*"
    ],
    "extraFiles": [
      {
        "from": "bridge.py",
        "to": "bridge.py"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
